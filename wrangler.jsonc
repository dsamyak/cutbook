{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cutbook",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "dist/server/server.js",
  "observability": {
    "logs": {
      "enabled": false,
      "invocation_logs": true
    }
  },
  "assets": {
    "directory": "dist/client"
  }
}